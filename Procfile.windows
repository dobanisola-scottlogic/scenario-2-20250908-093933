web: java %JAVA_OPTS% -DmakeMovesTimeoutSeconds=5 -DmaxPhases=512 -DmaxVisibleDistance=6 -DcollectablesSpawnFrequency=0.2 -DbattleRadius=2 -DmaxCollectablesSpawnedPerPhase=4 -DminCollectableDistanceFromSpawn=8 -DspawnPhases=8 -DinitialiseTimeoutSeconds=30 -Ddw.server.connector.port=%PORT% -Ddw.database.url=%JDBC_LOCAL_DATABASE_URL% -jar server\build\libs\server-1.0-SNAPSHOT-all.jar server server-local.yml
