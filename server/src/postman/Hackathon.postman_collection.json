				{
					"name": "Get All Hackathons",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"\r",
									"pm.test(\"Response status code is 200\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"Response contains two hackathons\", function () {\r",
									"    const responseData = pm.response.json();\r",
									"\r",
									"    pm.expect(responseData.length).to.equal(3, \"total number of created hackathons\")\r",
									"    responseData.forEach(function (item) {\r",
									"        pm.expect(item.id).to.deep.include(\"PostmanHackathon\");\r",
									"        pm.expect(item.name).to.deep.include(\"postmanhackathon\");\r",
									"        pm.expect(item.games).to.exist.and.to.be.an('array');\r",
									"        pm.expect(item.games.length).to.eql(0, \"games array will not be populated\");\r",
									"        pm.expect(item.teams).to.exist.and.to.be.an('array');\r",
									"        pm.expect(item.teams.length).to.eql(0, \"Teams array will not be populated\");\r",
									"        pm.expect(item.currentMilestoneClassName).to.eql(\"com.scottlogic.hackathon.bots.Milestone1Bot\");\r",
									"        pm.expect(item.currentMilestoneMap).to.eql(\"Easy\");\r",
									"    });\r",
									"});\r",
									"\r",
									"pm.test(\"Validate games and teams arrays\", function () {\r",
									"    const responseData = pm.response.json();\r",
									"\r",
									"    pm.expect(responseData).to.be.an('array');\r",
									"\r",
									"    responseData.forEach(function (item) {\r",
									"        pm.expect(item.games).to.exist.and.to.be.an('array');\r",
									"        pm.expect(item.games.length).to.equal(0, \"Expected games array to be empty\");\r",
									"\r",
									"        pm.expect(item.teams).to.exist.and.to.be.an('array');\r",
									"        pm.expect(item.teams.length).to.equal(0, \"Expected teams array to be empty\");\r",
									"    });\r",
									"});\r",
									"\r",
									"pm.test(\"Validate id and name fields are non-empty strings\", function () {\r",
									"    const responseData = pm.response.json();\r",
									"\r",
									"    pm.expect(responseData).to.be.an('array').that.is.not.empty;\r",
									"\r",
									"    responseData.forEach(function (item) {\r",
									"        pm.expect(item.id).to.be.a('string').and.to.have.lengthOf.at.least(1, \"Value should not be empty\");\r",
									"        pm.expect(item.name).to.be.a('string').and.to.have.lengthOf.at.least(1, \"Value should not be empty\");\r",
									"    });\r",
									"});\r",
									"\r",
									""
								],
								"type": "text/javascript"
							}
						}
